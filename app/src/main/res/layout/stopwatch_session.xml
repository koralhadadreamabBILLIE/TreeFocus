<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1B1B"> <!-- Deep Dark Background -->

    <!-- Top Label -->
    <TextView
        android:id="@+id/tv_session_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="Focusing..."
        android:textColor="#C8E6C9"
        android:textSize="18sp"
        android:letterSpacing="0.1"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- The Timer Circle Container -->
    <FrameLayout
        android:id="@+id/timer_container"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_stop_session"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_session_type">

        <!-- A soft glowing background circle for the "Zen" feel -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/rounded_button_green"
            android:backgroundTint="#1A334D3F" /> <!-- Very faint forest green -->

        <!-- The Actual Stopwatch Numbers -->
        <TextView
            android:id="@+id/tv_stopwatch_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="00:00"
            android:textColor="#E58EBB"
            android:textSize="64sp"
            android:fontFamily="monospace"
            tools:text="12:45" />
    </FrameLayout>

    <!-- Motivational Quote -->
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Your tree grows as you stay focused."
        android:textAlignment="center"
        android:textColor="#99C8E6C9"
        android:textSize="14sp"
        android:fontFamily="sans-serif-light"
        app:layout_constraintBottom_toTopOf="@+id/btn_stop_session"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_percent="0.7" />

    <!-- Stop Button (Pink to match your theme) -->
    <Button
        android:id="@+id/btn_stop_session"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginBottom="64dp"
        android:backgroundTint="#E58EBB"
        android:text="Stop Study Session"
        android:textAllCaps="false"
        android:textColor="#1E1B1B"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_percent="0.8" />

</androidx.constraintlayout.widget.ConstraintLayout>